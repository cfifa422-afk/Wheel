modules = ["nodejs-24"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
WHEEL_OF_NAMES_API = "https://wheelofnames.com/api/v2"
MIN_SPIN_TIME = "3"
DEFAULT_SPIN_TIME = "3"
MAX_SPIN_TIME = "10"
MAX_VISIBLE_ENTRIES = "120"
BOT_VERSION = "DEV"
CLIENT_ID = "1522495012846178375"
CLIENT_PUBLIC_KEY = "24c0691d715f9806570a2b317c8fca5c531eb4f9680aa327680a158f6162ed33"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[ports]]
localPort = 3000
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["node", "src/app.ts"]
